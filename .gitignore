
# -------------------------------------------------------------
# Intellij - Rust Rover
# -------------------------------------------------------------
.idea


# -------------------------------------------------------------
# VISUAL PARADIGM
# -------------------------------------------------------------

#Visual Paradigm preference data
.vpprefdata/

# Visual Paradigm temporary files
*.vpp~*
*.vpp.working
*.vpp.working-journal

# Visual Paradigm lock files
*.lock
*.lck
.*.lck

# Visual Paradigm backup files
*.vpp.bak_*
*.vpd.bak_*
*.bak_*
*.vbak

# Visual Paradigm data files (usually generated)
*.vpd

# ---------------------------------------------------------------
# RUST
# ---------------------------------------------------------------

debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/


# -------------------------------------------------------------
# LaTeX / TeX
# -------------------------------------------------------------
# Archivos auxiliares y temporales generados por compilaciones LaTeX
*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz
*.nav
*.snm
*.vrb
*.ilg
*.idx

# Archivos generados (PDFs, DVI, PS)
*.dvi
*.ps

# Bibliografía y archivos de apoyo
*.bbl
*.blg

# Directorios de build/artefactos
_build/
build/

# Archivos temporales de editores
*~
*.swp
*.tmp

# MiKTeX / texmf local state
/texmf-var/

