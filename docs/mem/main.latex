\label{tab:results_rastrigin_80}
\begin{tabular}{lrrrr}
\hline
\textbf{Biblioteca} & \textbf{Mejor Resultado} & \textbf{Media} & \textbf{Std. Dev.} & \textbf{Tiempo (ms)} \\ \hline
\textbf{Roma (Propuesta)} & 629.32 & 664.41 & 35.36 & 13.21 \\
jMetal (Java) \cite{jmetal} & \textbf{528.25} & 666.17 & 89.56 & 83.86 \\
jMetalPy \cite{jmetalpy} & 629.72 & 695.49 & 37.30 & 487.16 \\
pagmo2 (C++) \cite{pagmo} & 811.88 & 894.47 & 67.93 & \textbf{6.60} \\
DEAP \cite{deap} & 807.70 & 861.97 & 30.62 & 405.84 \\
Mealpy \cite{mealpy} & 859.08 & 934.23 & 51.58 & 373.66 \\ \hline
\end{tabular}
\end{table}

